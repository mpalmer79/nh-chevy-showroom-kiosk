# react-scripts@5.0.1 declares a peerOptional on typescript @^3||^4, but
# the project is on TypeScript 5.x. That mismatch is safe in practice —
# CRA 5.0.1 works with TS 5 — but npm 7+ strict peer-deps will refuse to
# install. This flag lets npm resolve instead of erroring, and applies
# globally to every `npm install` run (CI workflows, dev machines, lockfile
# regen). Drop this file once react-scripts is upgraded or the project
# migrates off CRA.
legacy-peer-deps=true
